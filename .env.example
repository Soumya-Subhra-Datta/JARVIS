# ============================================
# JARVIS - Environment Configuration
# ============================================
# Copy this file to .env and fill in your credentials
# Get free API keys at the links below

# Server
PORT=5000
NODE_ENV=development

# MySQL Database (TiDB Cloud Starter recommended — free 5GB, MySQL-compatible)
# Sign up: https://tidbcloud.com
# TiDB uses port 4000 and requires DB_SSL=true
# Alternatives: https://aiven.io, https://railway.app, https://clever-cloud.com, https://planetscale.com
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=jarvis_ai
DB_SSL=false

# JWT Authentication
JWT_SECRET=replace_with_long_secure_secret_key_min_32_chars

# Cerebras AI API
# Get free API key: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_MODEL=gpt-oss-120b

# Client URL (for CORS)
# Frontend deploy: https://vercel.com, https://netlify.com, https://render.com
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Feature Flags
ENABLE_LOCAL_AUTOMATION=false
MAX_FILE_UPLOAD_MB=10

# Optional: Web Search API (leave blank to disable)
# Free search: https://serpapi.com (100/mo), https://programmablesearchengine.google.com (100/day)
SEARCH_API_KEY=
SEARCH_API_PROVIDER=
